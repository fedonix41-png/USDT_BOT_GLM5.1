# Telegram
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Database (localhost for local dev; Docker overrides to postgres internally)
DATABASE_URL=postgresql+asyncpg://usdt_bot:secret@localhost:5432/usdt_bot

# Redis (localhost for local dev; Docker overrides to redis internally)
REDIS_URL=redis://localhost:6379/0

# ARQ Redis (separate DB for task queue; Docker overrides internally)
ARQ_REDIS_URL=redis://localhost:6379/1

# Encryption (32-byte hex key для AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# SuperAdmin Telegram ID (первый запуск)
SUPER_ADMIN_TELEGRAM_ID=123456789

# PostgreSQL password (for Docker)
POSTGRES_PASSWORD=secret
